# =========================
# MT5 Bridge Auth
# =========================
BRIDGE_API_KEY=change_me

# =========================
# Agent runtime mode
# - kernel: auto-trading enabled
# - user: suggestion only
# =========================
DEFAULT_AGENT_MODE=user

# =========================
# AI Provider Router (default Gemini)
# Supported values:
# - gemini             (Google Gemini native API, default)
# - openai_compatible  (OpenAI, DeepSeek, Moonshot, Qwen-compatible gateways, SiliconFlow, OpenRouter etc.)
# - anthropic          (Claude native API)
# =========================
AI_PROVIDER=gemini

# =========================
# Common AI settings
# =========================
AI_API_KEY=
AI_TIMEOUT_SECONDS=20
MAX_RISK_PERCENT=1.0
# AI调用节流（兼顾实时与省token）
AI_CALL_MIN_INTERVAL=10
AI_FORCE_INTERVAL=60
AI_TRIGGER_PRICE_BPS=1.5
# 每累计多少笔交易结果后触发一次策略复盘与参数更新
REVIEW_EVERY_N_TRADES=10

# -------------------------
# [Default] gemini (Google native)
# -------------------------
AI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_PATH_TEMPLATE=/v1beta/models/{model}:generateContent
AI_MODEL=gemini-2.5-flash
# 可选：本地代理（示例 http://127.0.0.1:7897）
GEMINI_PROXY_URL=
# 可选：使用 Vertex AI（google-genai SDK 会读取这些环境变量）
# GOOGLE_CLOUD_PROJECT=810669871257
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_GENAI_USE_VERTEXAI=True

# -------------------------
# [A] openai_compatible
# -------------------------
# AI_PROVIDER=openai_compatible
# AI_BASE_URL=https://api.openai.com/v1
OPENAI_PATH=/chat/completions
# AI_MODEL=gpt-4.1-mini

# OpenAI model examples:
# AI_MODEL=gpt-4.1-mini
# AI_MODEL=gpt-4.1
# AI_MODEL=o4-mini

# DeepSeek-compatible gateway examples:
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
# AI_MODEL=deepseek-reasoner

# Moonshot/Kimi-compatible gateway examples:
# AI_BASE_URL=https://api.moonshot.cn/v1
# AI_MODEL=moonshot-v1-8k
# AI_MODEL=moonshot-v1-32k

# Qwen-compatible gateway examples (if your provider exposes OpenAI format):
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-max
# AI_MODEL=qwen-plus

# -------------------------
# [B] anthropic (Claude native)
# -------------------------
# AI_PROVIDER=anthropic
# AI_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
# AI_MODEL=claude-3-7-sonnet-latest
# AI_MODEL=claude-3-5-sonnet-latest
# AI_MODEL=claude-3-5-haiku-latest

# Gemini model examples:
# AI_MODEL=gemini-2.5-pro
# AI_MODEL=gemini-2.5-flash
# AI_MODEL=gemini-2.0-flash
